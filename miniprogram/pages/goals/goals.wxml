<view class="goals-container">
  <view class="top-bar">
    <view>
      <text class="page-title">目标</text>
      <text class="page-subtitle">一起把钱和事推进，也允许有一点轻松的 PK。</text>
    </view>
  </view>

  <view class="loading-container" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载目标...</text>
  </view>

  <view class="empty-state card" wx:elif="{{pairState !== 'paired'}}">
    <text class="state-title">先连接共享空间</text>
    <text class="state-description">连好之后，这里才能开始设共同目标和本周挑战。</text>
    <button class="primary-button" bindtap="onGoSetupTap">去「我们」设置</button>
  </view>

  <scroll-view class="goals-scroll" wx:else scroll-y>
    <view class="goal-section card">
      <view class="section-head">
        <view>
          <text class="section-title">本月共同目标</text>
          <text class="section-subtitle">优先做省钱目标，也允许双方同意的预算对决。</text>
        </view>
      </view>

      <view class="active-goal-card" wx:if="{{overview && overview.monthlyGoal}}">
        <text class="active-goal-kicker">{{overview.monthlyGoal.label}}</text>
        <text class="active-goal-title">{{overview.monthlyGoal.title}}</text>
        <text class="active-goal-detail">{{overview.monthlyGoal.detail}}</text>
        <view class="active-goal-meta">
          <text class="active-goal-progress">{{overview.monthlyGoal.progressLabel}}</text>
          <text class="active-goal-current" wx:if="{{overview.monthlyGoal.currentLabel}}">{{overview.monthlyGoal.currentLabel}}</text>
          <text class="active-goal-wager" wx:if="{{overview.monthlyGoal.wagerStatusLabel}}">{{overview.monthlyGoal.wagerStatusLabel}}</text>
        </view>
        <view class="goal-actions">
          <view class="goal-action action-primary" data-target="{{overview.monthlyGoal.actionTarget}}" bindtap="onGoalActionTap">{{overview.monthlyGoal.actionLabel}}</view>
          <view class="goal-action" wx:if="{{overview.monthlyGoal.canSettle}}" data-slot="monthly_goal" bindtap="onSettleWager">标记已兑现</view>
          <view class="goal-action danger" data-slot="monthly_goal" bindtap="onArchiveGoal">归档目标</view>
        </view>
      </view>

      <view class="template-group" wx:for="{{monthlyGroups}}" wx:key="key">
        <view class="group-head">
          <text class="group-title">{{item.label}}</text>
        </view>
        <view class="template-grid">
          <view
            class="template-card {{monthlyForm.templateKey === subItem.key ? 'is-selected' : ''}} {{subItem.disabled ? 'is-disabled' : ''}}"
            wx:for="{{item.templates}}"
            wx:key="key"
            wx:for-item="subItem"
            data-slot="monthly_goal"
            data-key="{{subItem.key}}"
            bindtap="onTemplateTap"
          >
            <view class="template-head">
              <text class="template-title">{{subItem.label}}</text>
              <text class="template-mode {{subItem.mode}}">{{subItem.mode === 'competitive' ? '轻竞赛' : '共同推进'}}</text>
            </view>
            <text class="template-desc">{{subItem.description}}</text>
            <text class="template-hint" wx:if="{{subItem.hint}}">{{subItem.hint}}</text>
          </view>
        </view>
      </view>

      <view class="editor-card" wx:if="{{monthlyForm.templateKey}}">
        <text class="editor-title">创建本月目标</text>
        <input
          class="editor-input"
          placeholder="可以自定义一个标题（选填）"
          value="{{monthlyForm.customTitle}}"
          data-slot="monthly_goal"
          data-field="customTitle"
          bindinput="onFormInput"
        />
        <input
          class="editor-input"
          wx:if="{{monthlyForm.templateKey === 'save_buffer' || monthlyForm.templateKey === 'shared_spend_cap' || monthlyForm.templateKey === 'category_cap'}}"
          type="digit"
          placeholder="输入目标金额（元）"
          value="{{monthlyForm.targetValue}}"
          data-slot="monthly_goal"
          data-field="targetValue"
          bindinput="onFormInput"
        />
        <view class="category-picker" wx:if="{{monthlyForm.templateKey === 'category_cap'}}">
          <text class="editor-label">选择分类</text>
          <view class="category-chip-list">
            <view
              class="category-chip {{monthlyForm.categoryKey === item.key ? 'is-active' : ''}}"
              wx:for="{{categoryOptions}}"
              wx:key="key"
              data-slot="monthly_goal"
              data-key="{{item.key}}"
              bindtap="onCategoryTap"
            >
              {{item.label}}
            </view>
          </view>
        </view>
        <view class="wager-card" wx:if="{{monthlyForm.templateKey === 'budget_duel'}}">
          <view class="editor-switch-row">
            <text class="editor-switch-label">开启彩头</text>
            <switch color="#8a4d22" checked="{{monthlyForm.wagerEnabled}}" data-slot="monthly_goal" bindchange="onWagerToggle"></switch>
          </view>
          <input
            class="editor-input"
            wx:if="{{monthlyForm.wagerEnabled}}"
            type="digit"
            placeholder="彩头金额，例如 200"
            value="{{monthlyForm.wagerAmount}}"
            data-slot="monthly_goal"
            data-field="wagerAmount"
            bindinput="onFormInput"
          />
          <input
            class="editor-input"
            wx:if="{{monthlyForm.wagerEnabled}}"
            placeholder="彩头说明（选填）"
            value="{{monthlyForm.wagerLabel}}"
            data-slot="monthly_goal"
            data-field="wagerLabel"
            bindinput="onFormInput"
          />
        </view>
        <button class="primary-button compact" data-slot="monthly_goal" bindtap="onSaveGoal">保存本月目标</button>
      </view>
    </view>

    <view class="goal-section card">
      <view class="section-head">
        <view>
          <text class="section-title">本周挑战</text>
          <text class="section-subtitle">推进事情、拉起节奏，或者来一场轻松的 PK。</text>
        </view>
      </view>

      <view class="active-goal-card motion" wx:if="{{overview && overview.weeklyChallenge}}">
        <text class="active-goal-kicker">{{overview.weeklyChallenge.label}}</text>
        <text class="active-goal-title">{{overview.weeklyChallenge.title}}</text>
        <text class="active-goal-detail">{{overview.weeklyChallenge.detail}}</text>
        <view class="active-goal-meta">
          <text class="active-goal-progress">{{overview.weeklyChallenge.progressLabel}}</text>
          <text class="active-goal-current" wx:if="{{overview.weeklyChallenge.currentLabel}}">{{overview.weeklyChallenge.currentLabel}}</text>
          <text class="active-goal-wager" wx:if="{{overview.weeklyChallenge.wagerStatusLabel}}">{{overview.weeklyChallenge.wagerStatusLabel}}</text>
        </view>
        <view class="goal-actions">
          <view class="goal-action action-primary" data-target="{{overview.weeklyChallenge.actionTarget}}" bindtap="onGoalActionTap">{{overview.weeklyChallenge.actionLabel}}</view>
          <view class="goal-action" wx:if="{{overview.weeklyChallenge.canSettle}}" data-slot="weekly_challenge" bindtap="onSettleWager">标记已兑现</view>
          <view class="goal-action danger" data-slot="weekly_challenge" bindtap="onArchiveGoal">归档挑战</view>
        </view>
      </view>

      <view class="template-group" wx:for="{{weeklyGroups}}" wx:key="key">
        <view class="group-head">
          <text class="group-title">{{item.label}}</text>
        </view>
        <view class="template-grid">
          <view
            class="template-card motion {{weeklyForm.templateKey === subItem.key ? 'is-selected' : ''}} {{subItem.disabled ? 'is-disabled' : ''}}"
            wx:for="{{item.templates}}"
            wx:key="key"
            wx:for-item="subItem"
            data-slot="weekly_challenge"
            data-key="{{subItem.key}}"
            bindtap="onTemplateTap"
          >
            <view class="template-head">
              <text class="template-title">{{subItem.label}}</text>
              <text class="template-mode {{subItem.mode}}">{{subItem.mode === 'competitive' ? '轻竞赛' : '共同推进'}}</text>
            </view>
            <text class="template-desc">{{subItem.description}}</text>
            <text class="template-hint" wx:if="{{subItem.hint}}">{{subItem.hint}}</text>
          </view>
        </view>
      </view>

      <view class="editor-card motion" wx:if="{{weeklyForm.templateKey}}">
        <text class="editor-title">创建本周挑战</text>
        <input
          class="editor-input"
          placeholder="可以自定义一个标题（选填）"
          value="{{weeklyForm.customTitle}}"
          data-slot="weekly_challenge"
          data-field="customTitle"
          bindinput="onFormInput"
        />
        <input
          class="editor-input"
          wx:if="{{weeklyForm.templateKey === 'todo_clear' || weeklyForm.templateKey === 'workout_together' || weeklyForm.templateKey === 'steps_together' || weeklyForm.templateKey === 'weekly_spend_cap'}}"
          type="{{weeklyForm.templateKey === 'weekly_spend_cap' ? 'digit' : 'number'}}"
          placeholder="{{weeklyForm.templateKey === 'steps_together' ? '输入目标总步数' : (weeklyForm.templateKey === 'weekly_spend_cap' ? '输入本周共同支出上限（元）' : '输入目标值')}}"
          value="{{weeklyForm.targetValue}}"
          data-slot="weekly_challenge"
          data-field="targetValue"
          bindinput="onFormInput"
        />
        <view class="wager-card motion" wx:if="{{weeklyForm.templateKey === 'steps_duel'}}">
          <view class="editor-switch-row">
            <text class="editor-switch-label">开启彩头</text>
            <switch color="#4a7e72" checked="{{weeklyForm.wagerEnabled}}" data-slot="weekly_challenge" bindchange="onWagerToggle"></switch>
          </view>
          <input
            class="editor-input"
            wx:if="{{weeklyForm.wagerEnabled}}"
            type="digit"
            placeholder="彩头金额，例如 200"
            value="{{weeklyForm.wagerAmount}}"
            data-slot="weekly_challenge"
            data-field="wagerAmount"
            bindinput="onFormInput"
          />
          <input
            class="editor-input"
            wx:if="{{weeklyForm.wagerEnabled}}"
            placeholder="彩头说明（选填）"
            value="{{weeklyForm.wagerLabel}}"
            data-slot="weekly_challenge"
            data-field="wagerLabel"
            bindinput="onFormInput"
          />
        </view>
        <button class="primary-button compact motion" data-slot="weekly_challenge" bindtap="onSaveGoal">保存本周挑战</button>
      </view>
    </view>

    <view class="content-spacer"></view>
  </scroll-view>
</view>
