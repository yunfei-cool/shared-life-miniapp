page {
  background: #f3ece4;
  color: #241d1a;
}

.budget-container {
  min-height: 100vh;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at top right, rgba(217, 122, 61, 0.16), transparent 24%),
    radial-gradient(circle at 15% 30%, rgba(96, 78, 61, 0.06), transparent 22%),
    linear-gradient(180deg, #f6f0e8 0%, #efe5da 100%);
}

.top-bar {
  padding: 32rpx 32rpx 20rpx;
}

.page-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 52rpx;
  line-height: 1.04;
  font-weight: 600;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--neutral-muted);
  letter-spacing: 0.04em;
}

.loading-container {
  padding: 180rpx 32rpx;
  text-align: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(138, 77, 34, 0.16);
  border-top-color: #8a4d22;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #7e726a;
}

.card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(78, 56, 40, 0.08);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 44rpx rgba(69, 47, 34, 0.08);
}

.empty-state {
  margin: 40rpx 32rpx 0;
  padding: 40rpx 32rpx;
}

.state-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.28;
  font-weight: 700;
}

.state-description {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6e625c;
}

.budget-scroll {
  height: calc(100vh - 170rpx);
}

.summary-card,
.editor-card {
  margin: 0 32rpx 20rpx;
  padding: 30rpx 28rpx;
}

.summary-card {
  background:
    linear-gradient(145deg, rgba(248, 238, 229, 0.98), rgba(255, 251, 247, 0.96)),
    rgba(255, 255, 255, 0.92);
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: var(--finance-accent-strong);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.summary-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-main {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  flex-wrap: wrap;
}

.summary-spent {
  font-size: 56rpx;
  font-weight: 760;
  color: var(--finance-ink);
}

.summary-total {
  font-size: 28rpx;
  color: var(--neutral-muted);
  padding-bottom: 8rpx;
}

.summary-detail {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--neutral-text);
}

.progress-track {
  margin-top: 20rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(43, 33, 28, 0.08);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d97a3d 0%, #f0b387 100%);
}

.summary-meta {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-progress,
.summary-focus {
  font-size: 22rpx;
  color: var(--neutral-muted);
}

.shared-rule {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8b7c74;
}

.section-title {
  display: block;
  font-family: var(--font-serif);
  font-size: 34rpx;
  font-weight: 600;
}

.editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.editor-note {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--finance-accent-strong);
  padding-top: 6rpx;
}

.member-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(78, 56, 40, 0.06);
}

.member-copy {
  flex: 1;
  min-width: 0;
}

.member-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--finance-ink);
}

.member-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--neutral-muted);
}

.member-input-shell {
  width: 220rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(95, 70, 56, 0.08);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.currency-prefix {
  font-size: 28rpx;
  font-weight: 700;
  color: #8a4d22;
}

.member-input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  line-height: 84rpx;
}

.actions {
  margin: 0 32rpx;
}

.save-button {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: #2b211c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 14rpx 28rpx rgba(43, 33, 28, 0.16);
}

.save-button::after {
  border: none;
}

.content-spacer {
  height: 96rpx;
}
