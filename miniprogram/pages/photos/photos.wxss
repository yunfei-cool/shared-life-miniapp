/* photos.wxss - 照片页面样式 */

.photos-container {
  min-height: 100vh;
  background-color: #F9F9F9;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
}

/* 状态栏 */
.status-bar {
  padding: 32rpx 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2D3436;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background-color: #FFFFFF;
  color: #636E72;
  border: 1rpx solid #DFE6E9;
  transition: all 0.2s;
}

.action-btn.active {
  background-color: #FF6B8B;
  color: #FFFFFF;
  border-color: #FF6B8B;
}

/* 筛选栏 */
.filter-bar {
  padding: 0 32rpx 24rpx;
}

.filter-scroll {
  white-space: nowrap;
  height: 60rpx;
}

.filter-items {
  display: inline-flex;
  gap: 16rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background-color: #FFFFFF;
  color: #636E72;
  border: 1rpx solid #DFE6E9;
  transition: all 0.2s;
  flex-shrink: 0;
}

.filter-item.active {
  background-color: #FF6B8B;
  color: #FFFFFF;
  border-color: #FF6B8B;
}

/* 上传进度 */
.upload-progress {
  padding: 16rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #DFE6E9;
}

.progress-bar {
  height: 8rpx;
  background-color: #DFE6E9;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background-color: #00B894;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #636E72;
  text-align: center;
  display: block;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #DFE6E9;
  border-top-color: #FF6B8B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #636E72;
}

/* 空状态 */
.empty-state-container {
  padding: 120rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-state-illustration {
  font-size: 120rpx;
  margin-bottom: 48rpx;
}

.empty-state-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
  display: block;
}

.empty-state-description {
  font-size: 28rpx;
  color: #636E72;
  line-height: 1.5;
  margin-bottom: 48rpx;
  display: block;
}

.empty-state-actions {
  width: 100%;
}

.btn-primary {
  background-color: #FF6B8B;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 48rpx;
  border: none;
  width: 100%;
}

.btn-primary::after {
  border: none;
}

/* 照片内容 */
.photos-content {
  height: calc(100vh - 200rpx);
}

/* 编辑工具栏 */
.edit-toolbar {
  padding: 16rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #DFE6E9;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-count {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
}

.edit-actions {
  display: flex;
  gap: 32rpx;
}

.edit-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #636E72;
}

.edit-action.delete {
  color: #D63031;
}

.edit-action .icon {
  font-size: 28rpx;
}

/* 照片网格 */
.photos-grid {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
}

.photo-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s;
}

.photo-item:active {
  transform: scale(0.98);
}

.photo-item.edit-mode {
  border: 3rpx solid transparent;
}

.photo-item.edit-mode.selected {
  border-color: #FF6B8B;
}

/* 选择器 */
.photo-selector {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  z-index: 10;
}

.selector-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-checkbox.checked {
  background-color: #FF6B8B;
  border-color: #FF6B8B;
}

.selector-checkbox .checkmark {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
}

/* 照片缩略图 */
.photo-thumbnail {
  width: 100%;
  aspect-ratio: 1;
  display: block;
}

/* 照片信息 */
.photo-info {
  padding: 12rpx;
}

.photo-header {
  margin-bottom: 8rpx;
}

.photo-title {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.photo-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.photo-uploader {
  font-size: 22rpx;
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
}

.photo-uploader.me {
  background-color: rgba(255, 107, 139, 0.1);
  color: #FF6B8B;
}

.photo-uploader.partner {
  background-color: rgba(78, 205, 196, 0.1);
  color: #4ECDC4;
}

.photo-uploader.both {
  background-color: rgba(108, 92, 231, 0.1);
  color: #6C5CE7;
}

.photo-date {
  font-size: 22rpx;
  color: #B2BEC3;
}

/* 照片互动按钮 */
.photo-actions {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #DFE6E9;
  padding-top: 8rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #636E72;
}

.action-item .icon {
  font-size: 24rpx;
}

.action-item .count {
  font-weight: 600;
}

/* 空白区域 */
.content-spacer {
  height: 160rpx;
}

/* 浮动按钮 */
.fab-container {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  right: 32rpx;
  z-index: 100;
}

.fab-button {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #FF6B8B;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 139, 0.3);
  border: none;
  transition: transform 0.2s, box-shadow 0.2s;
}

.fab-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 139, 0.2);
}

.fab-button::after {
  border: none;
}

.fab-icon {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
}

/* 响应式调整 */
@media screen and (min-width: 414px) {
  .photos-container {
    max-width: 750rpx;
    margin: 0 auto;
  }

  .photos-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}