page {
  background: #f4ece2;
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
  position: relative;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 28rpx;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

:root {
  --font-sans: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Segoe UI", sans-serif;
  --font-serif: "Iowan Old Style", "Baskerville", "Palatino Linotype", "Songti SC", Georgia, serif;

  --finance-ink: #2f241f;
  --finance-accent: #a06744;
  --finance-accent-strong: #774a33;
  --finance-accent-soft: rgba(160, 103, 68, 0.13);
  --finance-surface: linear-gradient(155deg, rgba(248, 236, 226, 0.98), rgba(255, 252, 248, 0.92));

  --relationship-ink: #705b61;
  --relationship-accent: #bc9298;
  --relationship-accent-strong: #966f77;
  --relationship-accent-soft: rgba(188, 146, 152, 0.14);
  --relationship-surface: linear-gradient(150deg, rgba(248, 238, 237, 0.98), rgba(255, 252, 250, 0.94));

  --motion-ink: #355e54;
  --motion-accent: #5c8e82;
  --motion-accent-strong: #497368;
  --motion-accent-soft: rgba(92, 142, 130, 0.14);
  --motion-surface: linear-gradient(150deg, rgba(236, 246, 241, 0.98), rgba(255, 252, 249, 0.94));

  --neutral-ink: #2b211c;
  --neutral-text: #6b6058;
  --neutral-muted: #8e8177;
  --neutral-soft: #f7efe6;
  --neutral-paper: #fcf7f0;
  --neutral-line: rgba(78, 56, 40, 0.07);
  --neutral-card: rgba(255, 252, 248, 0.88);
  --neutral-overlay: rgba(0, 0, 0, 0.5);
  --paper-warm: #f7f0e7;
  --paper-rose: #f6efee;
  --paper-moss: #edf5f1;
  --hairline-warm: rgba(78, 56, 40, 0.06);
  --hairline-strong: rgba(78, 56, 40, 0.11);

  --shadow-sm: 0 8rpx 18rpx rgba(63, 45, 33, 0.05);
  --shadow-md: 0 16rpx 32rpx rgba(63, 45, 33, 0.08);
  --shadow-lg: 0 24rpx 48rpx rgba(63, 45, 33, 0.1);
  --shadow-primary: 0 16rpx 40rpx rgba(160, 103, 68, 0.16);

  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 48rpx;
  --radius-full: 9999rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --spacing-2xl: 64rpx;

  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 30rpx;
  --font-size-xl: 32rpx;
  --font-size-2xl: 36rpx;
  --font-size-3xl: 40rpx;
  --font-size-4xl: 48rpx;
}

.font-bold { font-weight: 600; }
.font-semibold { font-weight: 500; }
.font-normal { font-weight: 400; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-start { justify-content: flex-start; }
.justify-end { justify-content: flex-end; }

.w-full { width: 100%; }
.h-full { height: 100%; }

.m-0 { margin: 0; }
.p-0 { padding: 0; }

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 8rpx;
  height: 8rpx;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--neutral-line);
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--neutral-muted);
}

/* 安全区域适配 */
.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 全局按钮样式覆盖 */
button[type="primary"] {
  background-color: var(--finance-accent);
  color: #ffffff;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-md);
  font-weight: 600;
  padding: var(--spacing-md) var(--spacing-xl);
  border: none;
}

button[type="primary"]::after {
  border: none;
}

button[type="default"] {
  background-color: #ffffff;
  color: var(--finance-accent);
  border: 2rpx solid var(--finance-accent);
  border-radius: var(--radius-xl);
  font-size: var(--font-size-md);
  font-weight: 600;
  padding: calc(var(--spacing-md) - 2rpx) var(--spacing-xl);
}

button[type="default"]::after {
  border: none;
}

button[type="warn"] {
  background-color: #ffffff;
  color: #b0444f;
  border: 2rpx solid #b0444f;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-md);
  font-weight: 600;
  padding: calc(var(--spacing-md) - 2rpx) var(--spacing-xl);
}

button[type="warn"]::after {
  border: none;
}

/* 加载动画 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(78, 56, 40, 0.1);
  border-top-color: var(--finance-accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.finance-surface {
  background: var(--finance-surface), rgba(255, 255, 255, 0.92);
}

.relationship-surface {
  background: var(--relationship-surface), rgba(255, 255, 255, 0.92);
}

.motion-surface {
  background: var(--motion-surface), rgba(255, 255, 255, 0.92);
}

.motion-surface.soft {
  background: linear-gradient(145deg, rgba(240, 248, 244, 0.96), rgba(255, 255, 255, 0.92));
}

.serif-display {
  font-family: var(--font-serif);
  letter-spacing: -0.02em;
}

/* 模态框动画 */
@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
